# Sophon - Environment Variables
# Copy this file to .env and fill in your values.
# The app reads these directly from the environment (no dotenv auto-loading).
# Run: export $(cat .env | xargs) before starting the server.

# ── LLM Providers (at least one required) ─────────────────────────────────────

# DeepSeek (default provider)
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat                          # optional, default: deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1       # optional, change for proxies

# Qwen / DashScope (alternative provider)
# Get your key at: https://dashscope.aliyun.com/
# DASHSCOPE_API_KEY=sk-...
# QWEN_MODEL=qwen-plus                                # optional, default: qwen-plus
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── Server ─────────────────────────────────────────────────────────────────────

# API server port (default: 8080)
# PORT=8080

# ── Optional: Crawler (Playwright) ────────────────────────────────────────────
# Default crawler uses Playwright. First run: playwright install chromium

# ── Optional: MCP (only if skills use Firecrawl etc) ───────────────────────────
# python run_mcp_bridge.py; set SOPHON_MCP_BRIDGE_URL=http://127.0.0.1:8765
# FIRECRAWL_API_KEY=fc-...  # when using Firecrawl MCP

# ── Optional: Search ───────────────────────────────────────────────────────────

# DuckDuckGo search is used via the built-in search skill (no API key needed).
# If you want to use a different search backend, implement a custom search skill.
