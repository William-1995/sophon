# Sophon environment variables
# Copy to .env and set values. The app reads the process environment (no dotenv in app).
# Example load: export $(grep -v '^#' .env | xargs)

# LLM providers (at least one required)

# DeepSeek (default)
# Get your key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat                          # optional, default: deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1       # optional, change for proxies

# Qwen / DashScope (alternative provider)
# Get your key at: https://dashscope.aliyun.com/
# DASHSCOPE_API_KEY=sk-...
# QWEN_MODEL=qwen-plus                                # optional, default: qwen-plus
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Server

# API listen port (default: DEFAULT_API_PORT in config.py)
# PORT=

# Optional: generic human-decision tool (default off)
# Delete confirmation stays on filesystem __decision_request (no env needed).
# Set to 1 only if you want the model to call request_human_decision for multi-choice prompts.
# SOPHON_HITL_ENABLED=1

# Optional: crawler (Playwright). First run: playwright install chromium

# Optional: MCP bridge (if skills need it)
# python run_mcp_bridge.py; set SOPHON_MCP_BRIDGE_URL=http://127.0.0.1:8765
# FIRECRAWL_API_KEY=fc-...  # when using Firecrawl MCP

# Optional: search

# Built-in search skill uses DuckDuckGo (no API key).
# If you want to use a different search backend, implement a custom search skill.
